model Article {
  id          String @id
  type        String
  status      String
  title       String
  desc        String
  content     String
  publishedAt DateTime
  createdAt   DateTime
}

model Column {
  id   String @id
  name String
}

model Tag {
  id   String @id
  name String
}

model Series {
  id   String @id
  name String
}

model ArticlesOnColumns {
  articleId String
  columnId  String

  @@id([articleId, columnId])
}

model ArticlesOnTags {
  articleId String
  tagId     String

  @@id([articleId, tagId])
}

model SeriesOnArticles {
  articleId String
  seriesId  String

  @@id([articleId, seriesId])
}

model ArticleMetric {
  articleId String @id
  views     Int
  likes     Int
}

